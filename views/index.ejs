<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NodeJS </title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
    }
    .container {
      text-align: center;
      padding: 40px;
      background: rgba(255,255,255,0.05);
      border-radius: 20px;
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.1);
      max-width: 600px;
      width: 90%;
    }
    h1 { font-size: 2.5rem; margin-bottom: 10px; color: #e94560; }
    p { font-size: 1.1rem; margin-bottom: 30px; color: #a8b2d8; }
    .badge {
      display: inline-block;
      background: #e94560;
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 0.85rem;
      margin-bottom: 30px;
    }
    .cards {
      display: flex;
      gap: 15px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 30px;
    }
    .card {
      background: rgba(255,255,255,0.08);
      padding: 20px;
      border-radius: 12px;
      width: 150px;
      border: 1px solid rgba(255,255,255,0.1);
    }
    .card h3 { font-size: 1.8rem; color: #e94560; }
    .card p { font-size: 0.8rem; color: #a8b2d8; margin: 0; }
    .links { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
    .btn {
      padding: 10px 24px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: bold;
      font-size: 0.9rem;
      transition: 0.3s;
    }
    .btn-primary { background: #e94560; color: white; }
    .btn-secondary {
      background: transparent;
      color: white;
      border: 1px solid rgba(255,255,255,0.3);
    }
    .btn:hover { opacity: 0.8; transform: translateY(-2px); }
    .status {
      margin-top: 20px;
      font-size: 0.85rem;
      color: #a8b2d8;
    }
    .dot {
      display: inline-block;
      width: 8px; height: 8px;
      background: #00ff88;
      border-radius: 50%;
      margin-right: 6px;
      animation: pulse 1.5s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.3; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="badge">v<%= version %></div>
    <h1>Hello DevOps! 🚀</h1>
    <p>Node.js app running on Kubernetes with CI/CD Pipeline</p>
    <div class="cards">
      <div class="card">
        <h3><%= requests %></h3>
        <p>Total Requests</p>
      </div>
      <div class="card">
        <h3>K8s</h3>
        <p>Orchestration</p>
      </div>
      <div class="card">
        <h3>EKS</h3>
        <p>Cloud Platform</p>
      </div>
    </div>
    <div class="links">
      <a href="/health" class="btn btn-primary">Health Check</a>
      <a href="/metrics" class="btn btn-secondary">Metrics</a>
    </div>
    <div class="status">
      <span class="dot"></span> Server running on port 3000
    </div>
  </div>
</body>
</html>
